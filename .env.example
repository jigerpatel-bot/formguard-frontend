# ── API ──────────────────────────────────────────────────────
# Your backend URL (use localhost during development)
VITE_API_URL=http://localhost:3001

# ── Stripe (public key only — never put secret key here) ─────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── Dropbox Sign (client ID for embedded signing) ────────────
VITE_DROPBOX_SIGN_CLIENT_ID=your_dropbox_sign_client_id_here

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=FormGuard
